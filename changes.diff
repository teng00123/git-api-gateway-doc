+                elif val.lower() in ("true", "false"):
+                    rtype = "boolean"
+                elif "serializer" in val.lower() or ".data" in val:
+                    rtype = "object"
+                elif val.startswith("["):
+                    rtype = "array"
+                elif val.startswith("{"):
+                    rtype = "object"
+                elif "Map.of" in val or "{" in val:
+                    rtype = "object"
+                params.append({
+                    "name": key,
+                    "type": rtype,
+                    "description": "",
+                })
