+    # ── 辅助：提取响应参数 ──────────────────────
+    def _extract_response_params(self, body_lines: list) -> list:
+        """
+        从 Response({...}) 中提取响应字段
+        支持:
+          - Response({'key': value, ...})
+          - Response(serializer.data)
+          - Response({'code': 200, 'data': ...})
