+        # 尝试提取 Response({...}) 内容
+        for m in re.finditer(r"Response\s*\(\s*\{([^}]{1,500})\}", body_text, re.DOTALL):
+            block = m.group(1)
+            for km in re.finditer(r"['\"](\w+)['\"]:\s*([^,}\n]+)", block):
+                key = km.group(1)
+                val = km.group(2).strip()
+                if key in seen:
+                    continue
+                seen.add(key)
+                # 推断类型
+                rtype = "string"
+                if re.match(r"^\d+$", val):
